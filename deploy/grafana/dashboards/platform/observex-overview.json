{
  "title": "ObserveX — Platform Overview",
  "uid": "observex-overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["observex", "platform"],
  "panels": [
    {
      "id": 1,
      "title": "Signals received (per service, per type)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (signal_type) (rate(observex_signals_received_total[1m]))",
          "legendFormat": "{{signal_type}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Signals dropped (by reason)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (reason) (rate(observex_signals_dropped_total[1m]))",
          "legendFormat": "{{reason}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Ingest pipeline queue depth",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 6 },
      "targets": [
        { "expr": "observex_pipeline_queue_depth" }
      ]
    },
    {
      "id": 4,
      "title": "WAL write latency (p95)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "x": 8, "y": 8, "w": 8, "h": 6 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(observex_wal_write_latency_seconds_bucket[1m])))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 5,
      "title": "Anomalies fired (by tenant)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 6 },
      "targets": [
        {
          "expr": "sum by (tenant) (rate(observex_anomalies_fired_total[5m]))",
          "legendFormat": "{{tenant}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "HTTP request rate (by service)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (job) (rate(http_requests_total[1m]))",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 7,
      "title": "Process resident memory",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "process_resident_memory_bytes",
          "legendFormat": "{{job}}"
        }
      ]
    }
  ]
}
